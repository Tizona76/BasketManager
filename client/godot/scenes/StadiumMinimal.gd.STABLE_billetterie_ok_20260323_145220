func _safe_int(txt: String) -> int:
	var t: String = txt.strip_edges()
	if t.is_empty():
		return 0
	var out: String = ""
	for i: int in range(t.length()):
		var code: int = t.unicode_at(i)
		if code >= 48 and code <= 57:
			out += String.chr(code)
	if out.is_empty():
		return 0
	return int(out)

func _get_shop_stock_for_level(level: int, pid: String) -> int:

	if tabs != null:
		tabs.z_as_relative = true
		tabs.z_index = 100
	if PanelClub != null:
		PanelClub.mouse_filter = Control.MOUSE_FILTER_IGNORE
	if PanelWinrates != null:
		PanelWinrates.mouse_filter = Control.MOUSE_FILTER_IGNORE
	# ----------------------------------------------------------------------

	# --- Finances: connect simple (comme Match) ---
	var _bf: Button = null
	if has_node("UI/BtnFinances"):
		_bf = get_node("UI/BtnFinances") as Button
	elif has_node("BtnFinances"):
		_bf = get_node("BtnFinances") as Button
	if _bf != null:
		_bf.disabled = false
		_bf.visible = true
		_bf.mouse_filter = Control.MOUSE_FILTER_STOP
		if not _bf.pressed.is_connected(_on_btn_finances):
			_bf.pressed.connect(_on_btn_finances)
	# BM_WINRATES_TABS_INIT_V1 -----------------------------------------------
	# Tabs: Club vs Winrates (Ranking)
	if BtnTabClub != null:
		if str(BtnTabClub.text).strip_edges() == "":
			BtnTabClub.text = "Club"
		if not BtnTabClub.pressed.is_connected(Callable(self, "_bm_on_tab_club")):
			BtnTabClub.pressed.connect(Callable(self, "_bm_on_tab_club"))

	if BtnTabWinrates != null:
		if str(BtnTabWinrates.text).strip_edges() == "":
			BtnTabWinrates.text = "Ranking"
		if not BtnTabWinrates.pressed.is_connected(Callable(self, "_bm_on_tab_winrates")):
			BtnTabWinrates.pressed.connect(Callable(self, "_bm_on_tab_winrates"))

	_ensure_music_toggle_button()

	# Par défaut: onglet Club

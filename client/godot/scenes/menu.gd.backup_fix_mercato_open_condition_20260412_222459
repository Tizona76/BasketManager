func _bm_club_tr_or_fallback(key: String, fallback: String = "") -> String:
	var v := tr(key)
	if v == key or v.strip_edges() == "":
		if fallback.strip_edges() != "":
			return fallback
		return _bm_club_popup_fallback(key)
	return v


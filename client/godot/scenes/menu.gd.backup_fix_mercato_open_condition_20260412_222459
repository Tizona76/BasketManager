func _bm_popup_cta_text() -> String:
	var tn := ""
	var save_any: Variant = PL.load_savegame()
	if typeof(save_any) == TYPE_DICTIONARY:
		var d := save_any as Dictionary
		tn = str(d.get("team_name", "")).strip_edges()
	if tn == "" and LblClubName != null:
		tn = LblClubName.text.strip_edges()
	if tn == "":
		return "Start by building"
	return "Start by building " + tn


func _bm_club_lang_code() -> String:
	var loc := TranslationServer.get_locale().to_lower()
	if loc.begins_with("fr"):
		return "fr"
	if loc.begins_with("es"):
		return "es"
	if loc.begins_with("it"):
		return "it"
	if loc.begins_with("pt"):
		return "pt"
	return "en"


	var wins: int = 0
	var losses: int = 0
	if d.has("progress") and typeof(d["progress"]) == TYPE_DICTIONARY:
		var p := d["progress"] as Dictionary
		journee = int(p.get("journee", 1))

	# W-L: source of truth = SeasonState.standings
	var ss := get_node_or_null("/root/SeasonState")
	if ss != null:
		var standings_any = ss.get("standings")
		if typeof(standings_any) == TYPE_DICTIONARY:
			var standings: Dictionary = standings_any as Dictionary
			if tn != "" and standings.has(tn) and typeof(standings[tn]) == TYPE_DICTIONARY:
				var club_row: Dictionary = standings[tn] as Dictionary

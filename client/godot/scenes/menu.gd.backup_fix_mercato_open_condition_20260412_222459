	)



func _set_network_state(s: String) -> void:
	if _network_state == s:
		return
	_network_state = s
	print("[NET] state=", _network_state)
	if _network_state == "OFFLINE":
		_start_offline_poll()
	elif _network_state == "ONLINE":
		_offline_poll_running = false


func _start_offline_poll() -> void:
	if _offline_poll_running:
		return
	_offline_poll_running = true
	_offline_poll_loop()


func _offline_poll_loop() -> void:
	if not _offline_poll_running:
		return

	var t := get_tree().create_timer(OFFLINE_POLL_INTERVAL_S)
	t.timeout.connect(func():
		if not _offline_poll_running:
			return

		# Si cloud inflight, on attend
		if _inflight != "":
			_offline_poll_loop()
			return

		var access: String = str(Session.access_token).strip_edges()
		var rt: String = str(Session.refresh_token).strip_edges()

		# ✅ Si refresh invalidé -> ne spam pas (attend nouveau login)
		if _auth_refresh_invalid:
			_set_status("Status: Session expirée (re-login requis)")
			print("[AUTH] refresh_invalid latched -> stop auth retries")
			_offline_poll_loop()
			return

		# ✅ OFFLINE-FIRST AUTH: si pas connecté mais refresh_token présent, on tente refresh
		if access.length() < 20 and rt.length() >= 10 and HttpAuth != null:
			var now_ms: int = Time.get_ticks_msec()
			if now_ms < _auth_next_try_ms:
				var left := float(_auth_next_try_ms - now_ms) / 1000.0
				print("[AUTH] backoff active, left=", left, "s")
				_offline_poll_loop()
				return

			print("[NET] offline poll -> try AUTH refresh (menu)")
			_try_auth_refresh(rt)
			_offline_poll_loop()
			return

		# ✅ Ne tente cloud load que si on a un access_token valide
		if access.length() >= 20:
			print("[NET] offline poll -> try cloud load")
			_try_cloud_load()
		else:
			_set_status("Status: Pas connecté")
			_set_network_state("OFFLINE")

		_offline_poll_loop()
	)


func _schedule_retry(kind: String, delay_s: float) -> void:
	if delay_s < 0.05:
		delay_s = 0.05
	print("[RETRY] schedule kind=", kind, " in ", delay_s, "s")
	_set_status("Status: Réseau… retry %s (%.1fs)" % [kind, delay_s])
	var t := get_tree().create_timer(delay_s)
	t.timeout.connect(func():
		if _inflight != "":
			print("[RETRY] skipped: inflight=", _inflight, " kind=", kind)
			return
		if kind == "load":
			_try_cloud_load()
		elif kind == "save":
			call_deferred("_try_cloud_save_from_local")
	)


# ------------------------------------------------------------
# ✅ STEP 2: flush dirty_local when back online
# ------------------------------------------------------------
func _maybe_flush_dirty_local(reason: String) -> void:
	if not _dirty_local:
		return
	if _inflight != "":
		print("[DIRTY] flush skipped (inflight=", _inflight, ") reason=", reason)
		return

	var access: String = str(Session.access_token).strip_edges()
	if access.length() < 20:
		print("[DIRTY] flush skipped (no access_token) reason=", reason)
		return

	var now_ms: int = Time.get_ticks_msec()
	if now_ms < _rt_cooldown_until_ms:
		var left: float = float(_rt_cooldown_until_ms - now_ms) / 1000.0
		print("[DIRTY] flush delayed by cooldown, left=", left, "s reason=", reason)
		return

	var local_ck: String = _sha256_canonical_from_file(FILE_SAVEGAME)
	if local_ck == "":
		print("[DIRTY] flush skipped: local checksum empty reason=", reason)
		return

	print("[DIRTY] flush -> push local (reason=", reason, ") local_ck=", local_ck)
	call_deferred("_try_cloud_save_from_local")



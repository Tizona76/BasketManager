func _bm_debug_token_hud(where: String) -> void:
	print("===== TOKEN HUD DEBUG @", where, " =====")
	print("[TOKHUD] ImgTokenHud node=", ImgTokenHud)
	print("[TOKHUD] LblHudTokens node=", LblHudTokens)

	if ImgTokenHud == null:
		print("[TOKHUD] ImgTokenHud=NULL")
		return

	print("[TOKHUD] visible=", ImgTokenHud.visible)
	print("[TOKHUD] modulate=", ImgTokenHud.modulate)
	print("[TOKHUD] self_modulate=", ImgTokenHud.self_modulate)
	print("[TOKHUD] position=", ImgTokenHud.position)
	print("[TOKHUD] size=", ImgTokenHud.size)
	print("[TOKHUD] custom_minimum_size=", ImgTokenHud.custom_minimum_size)
	print("[TOKHUD] expand_mode=", ImgTokenHud.expand_mode)
	print("[TOKHUD] stretch_mode=", ImgTokenHud.stretch_mode)
	print("[TOKHUD] texture=", ImgTokenHud.texture)
	print("[TOKHUD] texture_size=", ImgTokenHud.texture.get_size() if ImgTokenHud.texture != null else "NULL")
	print("[TOKHUD] path=", ImgTokenHud.get_path())

	var parent := ImgTokenHud.get_parent()
	print("[TOKHUD] parent=", parent)
	if parent != null:
		print("[TOKHUD] parent.visible=", parent.visible)
		print("[TOKHUD] parent.modulate=", parent.modulate)
		if parent is Control:
			print("[TOKHUD] parent.size=", (parent as Control).size)
			print("[TOKHUD] parent.position=", (parent as Control).position)

	if LblHudTokens != null:
		print("[TOKHUD] label.text=", LblHudTokens.text)
		print("[TOKHUD] label.visible=", LblHudTokens.visible)
		print("[TOKHUD] label.position=", LblHudTokens.position)
		print("[TOKHUD] label.size=", LblHudTokens.size)
	print("===== /TOKEN HUD DEBUG =====")



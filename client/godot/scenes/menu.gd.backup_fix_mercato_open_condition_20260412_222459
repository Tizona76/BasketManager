				losses = int(club_row.get("L", 0))

	if LblProgress != null:
		var s := tr("menu.day_progress")
		s = s.replace("{j}", str(journee)).replace("{w}", str(wins)).replace("{l}", str(losses))
		LblProgress.text = s

	# --- Title (optionnel)
	if Title != null:
		Title.text = tr("menu.title_with_club").replace("{club}", tn)

	print("[MENU] club=", tn, " euros=", euros, " tokens=", tokens, " j=", journee, " W-L=", wins, "-", losses)



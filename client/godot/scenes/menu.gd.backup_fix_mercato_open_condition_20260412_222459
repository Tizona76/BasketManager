func _ensure_local_savegame_exists() -> void:
	# 1) fichier existe -> migration soft (ajoute team_name si absent)
	if FileAccess.file_exists(FILE_SAVEGAME):
		var parsed: Variant = _read_json_file(FILE_SAVEGAME)
		if parsed != null and typeof(parsed) == TYPE_DICTIONARY:
			var d: Dictionary = parsed as Dictionary
			var changed: bool = false

			# Ajoute team_name si absent (préférence: club.name si déjà présent)
			if not d.has("team_name"):
				var tn: String = ""
				if d.has("club") and typeof(d["club"]) == TYPE_DICTIONARY:
					tn = str((d["club"] as Dictionary).get("name", "")).strip_edges()
				d["team_name"] = tn
				changed = true

			# Optionnel: si club.name vide mais team_name défini, on synchronise
			if d.has("team_name") and d.has("club") and typeof(d["club"]) == TYPE_DICTIONARY:
				var club: Dictionary = d["club"] as Dictionary
				var tn2: String = str(d.get("team_name", "")).strip_edges()
				if str(club.get("name", "")).strip_edges() == "" and tn2 != "":
					club["name"] = tn2
					d["club"] = club
					changed = true

			if changed:
				var tn_guard: String = str(d.get("team_name", "")).strip_edges()
				if tn_guard == "":
					print("[LOCAL_SKIP] empty team_name -> no patch")
				else:
					_save_text_file(FILE_SAVEGAME, JSON.stringify(d, "\t"))
					print("[LOCAL] patched savegame.json (team_name)")
		return

	# 2) fichier absent -> création (inclut team_name)
	var save := {
		"version": 1,
		"profile_uuid": str(Session.profile_uuid),
		"season_id": "2026-01",
		"team_name": "",
		"club": {"name": "BM Club", "level": 1, "xp": 0},
		"wallet": {"euros": 1200, "tokens": 0},
		"progress": {"journee": 1, "wins": 0, "losses": 0},
		"meta": {"created_at_unix": Time.get_unix_time_from_system()}
	}
	_save_text_file(FILE_SAVEGAME, JSON.stringify(save, "\t"))
	print("[LOCAL] created REAL savegame.json")


# ------------------------------------------------------------
# CHECKSUM (SHA-256 hex)
# ------------------------------------------------------------
func _sha256_hex(s: String) -> String:
	var ctx := HashingContext.new()
	ctx.start(HashingContext.HASH_SHA256)
	ctx.update(s.to_utf8_buffer())
	var digest: PackedByteArray = ctx.finish()
	return digest.hex_encode()


func _sha256_bytes_hex(b: PackedByteArray) -> String:
	var ctx := HashingContext.new()
	ctx.start(HashingContext.HASH_SHA256)
	ctx.update(b)
	var digest: PackedByteArray = ctx.finish()
	return digest.hex_encode()


func _sha256_file_hex(path: String) -> String:
	if not FileAccess.file_exists(path):
		return ""
	var f := FileAccess.open(path, FileAccess.READ)
	if f == null:
		return ""
	var b := f.get_buffer(f.get_length())
	f.close()
	return _sha256_bytes_hex(b)


# ------------------------------------------------------------
# CANONICAL JSON (stable checksum)
# ------------------------------------------------------------
func _canonicalize(v: Variant) -> Variant:
	var t: int = typeof(v)

	if t == TYPE_DICTIONARY:
		var d: Dictionary = v as Dictionary
		var keys: Array = d.keys()
		keys.sort_custom(func(a, b): return str(a) < str(b))

		var out: Dictionary = {}
		for k in keys:
			out[k] = _canonicalize(d[k])
		return out

	if t == TYPE_ARRAY:
		var a: Array = v as Array
		var out_arr: Array = []
		out_arr.resize(a.size())
		for i in range(a.size()):
			out_arr[i] = _canonicalize(a[i])
		return out_arr

	return v


func _json_compact(v: Variant) -> String:
	return JSON.stringify(v)


func _sha256_canonical_from_variant(v: Variant) -> String:
	var canon: Variant = _canonicalize(v)
	var s: String = _json_compact(canon)
	return _sha256_hex(s)


func _sha256_canonical_from_file(path: String) -> String:
	var parsed: Variant = _read_json_file(path)
	if parsed == null:
		return _sha256_file_hex(path)
	return _sha256_canonical_from_variant(parsed)



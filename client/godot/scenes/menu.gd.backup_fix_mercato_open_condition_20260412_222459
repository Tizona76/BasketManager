func _bm_wr_fmt_pct(x: float) -> String:
	var v := int(round(clamp(x, 0.0, 1.0) * 100.0))
	return str(v) + "%"

func _bm_wr_local_row() -> Dictionary:
	var local: Variant = _read_json_file(FILE_SAVEGAME)

	var club_name := "BM Club"
	var wins := 0
	var losses := 0
	var titles := 0
	var level := 1

	if typeof(local) == TYPE_DICTIONARY:
		var d := local as Dictionary
		club_name = str(d.get("team_name", "")).strip_edges()
		if club_name == "":
			if d.has("club") and typeof(d["club"]) == TYPE_DICTIONARY:
				club_name = str((d["club"] as Dictionary).get("name", "BM Club")).strip_edges()
		if club_name == "":
			club_name = "BM Club"

		if d.has("progress") and typeof(d["progress"]) == TYPE_DICTIONARY:
			var p := d["progress"] as Dictionary
			wins = int(p.get("wins", 0))
			losses = int(p.get("losses", 0))

		if d.has("club") and typeof(d["club"]) == TYPE_DICTIONARY:
			var c := d["club"] as Dictionary
			level = int(c.get("level", 1))
			titles = int(c.get("titles_total", 0))

		titles = int(d.get("titles_total", titles))

	var games := wins + losses
	var wr := 0.0
	if games > 0:
		wr = float(wins) / float(games)

	return {
		"rank": "—",
		"club": club_name + " (Me)",
		"winrate": _bm_wr_fmt_pct(wr),
		"titles_total": titles,
		"club_level": level
	}

func _bm_wr_show_loading() -> void:
	var rows: Array = []
	rows.append(_bm_wr_local_row())
	rows.append({"rank":"", "club":tr("ranking.loading"), "winrate":"", "titles_total":"", "club_level":""})
	_bm_wr_render_table(rows)

func _bm_wr_fetch_top() -> void:
	if HttpLb == null:
		print("[RANKING] HttpLb missing")
		return
	if _bm_wr_loading:
		return

	_bm_wr_loading = true
	_bm_wr_last_error = ""
	_bm_wr_show_loading()

	var season_id := "2026-01"
	var local: Variant = _read_json_file(FILE_SAVEGAME)
	if typeof(local) == TYPE_DICTIONARY:
		season_id = str((local as Dictionary).get("season_id", season_id)).strip_edges()
		if season_id == "":
			season_id = "2026-01"

	var url := API_BASE + PATH_LB_TOP + "?season_id=%s&sort=winrate&limit=50" % season_id

	var headers := PackedStringArray(["Accept: application/json"])
	var access := str(Session.access_token).strip_edges()
	if access.length() >= 20:
		headers.append("Authorization: Bearer %s" % access)

	print("[RANKING] GET ", url)
	_bm_lb_inflight = "top"
	var err := HttpLb.request(url, headers, HTTPClient.METHOD_GET)
	print("[RANKING] request err=", err)
	if err != OK:
		_bm_lb_inflight = ""
	if err != OK:
		_bm_wr_loading = false
		_bm_wr_last_error = "HTTP request() err=%s" % str(err)
		var rows: Array = []
		rows.append(_bm_wr_local_row())
		rows.append({"rank":"", "club":tr("ranking.http_error_prefix") + " " + _bm_wr_last_error, "winrate":"", "titles_total":"", "club_level":""})
		_bm_wr_render_table(rows)

func _bm_wr_on_http_completed(result: int, response_code: int, _headers: PackedStringArray, body: PackedByteArray) -> void:
	var body_txt := body.get_string_from_utf8()
	var mode := _bm_lb_inflight
	_bm_lb_inflight = ""

	if mode == "submit":
		print("[LB] response_code=", response_code, " result=", result, " body=", body_txt)
		if response_code >= 200 and response_code < 300:
			print("[LB] submit OK")
		else:
			print("[LB] submit KO code=", response_code, " body=", body_txt)
		return

	_bm_wr_loading = false
	print("[RANKING] response_code=", response_code)

	if response_code != 200:
		var rows: Array = []
		rows.append(_bm_wr_local_row())
		rows.append({"rank":"", "club":"Server error " + str(response_code), "winrate":"", "titles_total":"", "club_level":""})
		_bm_wr_render_table(rows)
		return

	var parsed: Variant = JSON.parse_string(body_txt)
	if typeof(parsed) != TYPE_DICTIONARY:
		var rows2: Array = []
		rows2.append(_bm_wr_local_row())
		rows2.append({"rank":"", "club":tr("ranking.invalid_json"), "winrate":"", "titles_total":"", "club_level":""})
		_bm_wr_render_table(rows2)
		return

	var data: Dictionary = parsed as Dictionary

	var items: Array = []
	if data.has("items") and typeof(data["items"]) == TYPE_ARRAY:
		items = data["items"] as Array
	elif data.has("top") and typeof(data["top"]) == TYPE_ARRAY:
		items = data["top"] as Array

	var rows: Array = []
	rows.append(_bm_wr_local_row())

	var rank: int = 1
	for it in items:
		if typeof(it) != TYPE_DICTIONARY:
			continue
		var r := it as Dictionary

		var club := str(r.get("club", "")).strip_edges()
		if club == "":
			club = str(r.get("pseudo", "")).strip_edges()
		if club == "":
			club = "?"

		var wr_val: Variant = r.get("winrate", 0.0)
		var wr := ""
		if typeof(wr_val) == TYPE_FLOAT or typeof(wr_val) == TYPE_INT:
			wr = _bm_wr_fmt_pct(float(wr_val))
		else:
			wr = str(wr_val)

		rows.append({
			"rank": rank,
			"club": club,
			"winrate": wr,
			"titles_total": int(r.get("titles_total", 0)),
			"club_level": int(r.get("club_level", 1)),
		})
		rank += 1

	_bm_wr_last_rows = rows
	_bm_wr_render_table(rows)


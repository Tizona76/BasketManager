# ------------------------------------------------------------
# AUTH REFRESH (menu-level, dédié)
# ------------------------------------------------------------
func _try_auth_refresh(rt: String) -> void:
	if HttpAuth == null:
		return
	if _auth_inflight:
		return

	if rt.strip_edges().length() < 10:
		return

	_auth_inflight = true
	_auth_last_rt = rt
	_auth_retry_count = 0

	_set_status("Status: Offline → reconnexion…")

	var url := API_BASE + PATH_AUTH_REFRESH
	var headers := PackedStringArray(["Content-Type: application/json"])
	var body := JSON.stringify({"refresh_token": rt})

	print("[AUTH][REFRESH] POST ", url, " rt_len=", str(rt.length()))
	var err := HttpAuth.request(url, headers, HTTPClient.METHOD_POST, body)
	print("[AUTH][REFRESH] request err=", err)

	if err != OK:
		_auth_inflight = false
		_set_network_state("OFFLINE")
		print("[AUTH][REFRESH] request() failed err=", err)
		return


func _on_auth_completed(result: int, response_code: int, _headers: PackedStringArray, body: PackedByteArray) -> void:
	var txt := body.get_string_from_utf8()
	print("[AUTH][REFRESH] result=", result, " code=", response_code, " body=", txt)

	# --- network fail
	if result != OK or response_code == 0:
		_set_network_state("OFFLINE")

		if _auth_retry_count < AUTH_RETRY_MAX:
			_auth_retry_count += 1
			print("[AUTH][REFRESH] retry in ", str(AUTH_RETRY_DELAY_S), "s ... count=", str(_auth_retry_count))
			await get_tree().create_timer(AUTH_RETRY_DELAY_S).timeout

			var rt2 := str(Session.refresh_token).strip_edges()
			if rt2 != _auth_last_rt:
				print("[AUTH][REFRESH] token changed during retry -> abort")
				_auth_inflight = false
				return

			var url := API_BASE + PATH_AUTH_REFRESH
			var headers := PackedStringArray(["Content-Type: application/json"])
			var body2 := JSON.stringify({"refresh_token": rt2})
			var err := HttpAuth.request(url, headers, HTTPClient.METHOD_POST, body2)
			print("[AUTH][REFRESH] retry request err=", err)
			if err != OK:
				_auth_inflight = false
			return

		print("[AUTH][REFRESH] retries exhausted (network) -> stay offline")
		_auth_inflight = false
		_set_status("Status: Offline (pas connecté)")

		_auth_next_try_ms = Time.get_ticks_msec() + int(_auth_backoff_s * 1000.0)
		print("[AUTH] next try in ", _auth_backoff_s, "s")
		_auth_backoff_s = min(_auth_backoff_s * 2.0, AUTH_BACKOFF_MAX_S)

		_start_offline_poll()
		return

	# --- http fail
	if response_code < 200 or response_code >= 300:
		print("[AUTH][REFRESH] http fail code=", response_code, " body=", txt)
		_auth_inflight = false

		# ✅ REFRESH_INVALID -> purge + latch (évite boucle infinie)
		if response_code == 401 or txt.find("REFRESH_INVALID") != -1:
			print("[AUTH][REFRESH] REFRESH_INVALID -> purge session + latch")
			Session.refresh_token = ""
			Session.access_token = ""
			_save_session_local_from_menu()
			_auth_refresh_invalid = true
			_set_status("Status: Session expirée (login requis)")
			_set_network_state("OFFLINE")
			_start_offline_poll()
			return

		_auth_next_try_ms = Time.get_ticks_msec() + int(_auth_backoff_s * 1000.0)
		_auth_backoff_s = min(_auth_backoff_s * 2.0, AUTH_BACKOFF_MAX_S)

		if response_code == 400 and txt.find("BAD_REFRESH") != -1:
			_set_status("Status: Session expirée (login requis)")
		else:
			_set_status("Status: Offline (auth KO)")

		_start_offline_poll()
		return

	# --- parse json
	var parsed: Variant = JSON.parse_string(txt)
	if typeof(parsed) != TYPE_DICTIONARY:
		print("[AUTH][REFRESH] invalid json")
		_auth_inflight = false
		_set_status("Status: Offline (auth invalide)")
		_start_offline_poll()
		return

	var d := parsed as Dictionary
	var at := str(d.get("access_token", "")).strip_edges()
	var new_rt := str(d.get("refresh_token", "")).strip_edges()
	var tt := str(d.get("token_type", "Bearer")).strip_edges()

	if tt.to_lower() == "bearer":
		tt = "Bearer"

	if at.length() < 20:
		print("[AUTH][REFRESH] missing/short access_token")
		_auth_inflight = false
		_set_status("Status: Offline (auth short)")
		_start_offline_poll()
		return

	if new_rt == "":
		new_rt = str(Session.refresh_token).strip_edges()

	Session.set_tokens(at, new_rt, tt)
	print("[AUTH][REFRESH_OK] access_len=", str(Session.access_token.length()),
		" refresh_len=", str(str(Session.refresh_token).strip_edges().length()),
		" token_type=", str(Session.token_type),
		" profile_uuid=", str(Session.profile_uuid))

	_auth_backoff_s = 6.0
	_auth_next_try_ms = 0
	_auth_refresh_invalid = false

	_save_session_local_from_menu()

	_auth_inflight = false
	_set_network_state("ONLINE")
	_set_status("Status: Reconnecté ✅")

	if _inflight == "":
		_try_cloud_load()

	_maybe_flush_dirty_local("auth_reconnect")



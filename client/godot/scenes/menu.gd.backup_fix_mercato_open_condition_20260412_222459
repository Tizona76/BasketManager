func _find_first_texture_rect(n: Node) -> TextureRect:
	if n == null:
		return null
	for c in n.get_children():
		if c is TextureRect:
			return c as TextureRect
		var sub := _find_first_texture_rect(c)
		if sub != null:
			return sub
	return null



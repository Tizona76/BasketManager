func _bm_lb_submit_from_save() -> void:
	if HttpLb == null:
		print("[LB] HttpLb missing")
		return

	var access := str(Session.access_token).strip_edges()
	var puuid := str(Session.profile_uuid).strip_edges()
	if access.length() < 20:
		print("[LB] skip submit: no access token")
		return
	if puuid == "":
		print("[LB] skip submit: no profile_uuid")
		return

	var local: Variant = _read_json_file(FILE_SAVEGAME)
	if typeof(local) != TYPE_DICTIONARY:
		print("[LB] skip submit: save not dict")
		return

	var d := local as Dictionary

	var season_id := str(d.get("season_id", "2026-01")).strip_edges()
	if season_id == "":
		season_id = "2026-01"

	var club := str(d.get("team_name", "")).strip_edges()
	if club == "" and d.has("club") and typeof(d["club"]) == TYPE_DICTIONARY:
		club = str((d["club"] as Dictionary).get("name", "")).strip_edges()
	if club == "":
		print("[LB] skip submit: empty club")
		return

	var pseudo := club

	var club_level := PL.get_club_level(d)
	var titles_total := 0
	if d.has("club") and typeof(d["club"]) == TYPE_DICTIONARY:
		var c := d["club"] as Dictionary
		titles_total = int(c.get("titles_total", 0))
	titles_total = int(d.get("titles_total", titles_total))

	var wins := 0
	var losses := 0
	if d.has("progress") and typeof(d["progress"]) == TYPE_DICTIONARY:
		var prog := d["progress"] as Dictionary
		wins = int(prog.get("wins", 0))
		losses = int(prog.get("losses", 0))

	var total_games := wins + losses
	var winrate := 0.0
	if total_games > 0:
		winrate = float(wins) / float(total_games)

	var score_final := 0
	score_final += wins * 3
	score_final += titles_total * 100
	score_final += club_level * 10

	var payload := {
		"season_id": season_id,
		"profile_uuid": puuid,
		"pseudo": pseudo,
		"club": club,
		"club_level": club_level,
		"titles_total": titles_total,
		"winrate": winrate,
		"score_final": score_final,
		"meta": {
			"wins": wins,
			"losses": losses,
			"games": total_games
		},
		"client_sig": ""
	}

	var headers := PackedStringArray()
	headers.append("Authorization: Bearer %s" % access)
	headers.append("Accept: application/json")
	headers.append("Content-Type: application/json")

	var url := API_BASE + PATH_LB_SUBMIT
	var body_txt := JSON.stringify(payload)

	print("[LB] POST ", url)
	print("[LB] payload club=", club, " season_id=", season_id, " winrate=", winrate, " score_final=", score_final)

	_bm_lb_inflight = "submit"
	var err := HttpLb.request(url, headers, HTTPClient.METHOD_POST, body_txt)
	print("[LB] request err=", err)
	if err != OK:
		_bm_lb_inflight = ""

func _bm_place_token_icon_after_label(lbl: Label) -> void:
	if lbl == null or not is_instance_valid(lbl):
		return
	if not lbl.visible:
		return

	var host: Control = null
	var p := lbl.get_parent()

	if p != null and p is VBoxContainer and p.get_parent() != null and p.get_parent() is Control:
		host = p.get_parent() as Control
	elif p != null and p is Control:
		host = p as Control

	if host == null:
		return

	var icon := host.get_node_or_null("TokenIcon") as TextureRect
	if icon == null:
		icon = TextureRect.new()
		icon.name = "TokenIcon"
		icon.mouse_filter = Control.MOUSE_FILTER_IGNORE
		icon.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
		icon.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
		icon.z_as_relative = true
		icon.z_index = 50
		host.add_child(icon)

	var tex := load("res://assets/images/token.png") as Texture2D
	if tex == null:
		return

	icon.texture = tex
	icon.custom_minimum_size = Vector2(18, 18)
	icon.size = Vector2(18, 18)
	icon.visible = true

	var base_x := lbl.position.x
	var base_y := lbl.position.y

	if p != null and p is VBoxContainer:
		base_x += (p as VBoxContainer).position.x
		base_y += (p as VBoxContainer).position.y

	# devant le texte, comme les 2 autres écrans actuellement
	icon.position = Vector2(
		base_x - 24.0,
		base_y + max(0.0, (lbl.size.y - 18.0) * 0.5)
	)

func _bm_is_mercato_open_now() -> bool:
	var save: Dictionary = {}
	var PL = load("res://scripts/PlayerLife.gd")
	if PL != null and PL.has_method("load_savegame"):
		save = PL.load_savegame()

	var season_number: int = int(save.get("season_number", 1))
	print("[MERCATO][MENU] season_number=", season_number)
	return season_number >= 2


func _bm_get_mercato_current_journee() -> int:
	var PL = load("res://scripts/PlayerLife.gd")
	if PL == null:
		return 0

	var save: Dictionary = {}
	if PL.has_method("load_savegame"):
		save = PL.load_savegame()

	if save.has("progress") and save["progress"] is Dictionary:
		var progress: Dictionary = save["progress"]
		return max(0, int(progress.get("journee", 0)))

	return 0



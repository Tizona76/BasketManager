func _tr_safe(key: String) -> String:
	var s := tr(key)
	if s != key:
		return s

	# Fallback minimal TEMPORAIRE (le temps que le pipeline i18n régénère les traductions)
	# -> à supprimer quand _tr_safe("menu.btn_save") renvoie bien "Sauvegarder"
	match key:
		"menu.btn_save":
			return "Save"
			return "Sauvegarder"
		"menu.save_ok":
			return "Save OK"
			return "Sauvegarde OK"
		_:
			return key



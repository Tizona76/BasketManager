func _ensure_gestion_bg_is_root_layer() -> void:
	if BgGestion == null:
		return

	# Si le BG est dans un Container, ses anchors/size sont pilotés => on le sort
	var p := BgGestion.get_parent()
	if p != null and p != self:
		p.remove_child(BgGestion)
		add_child(BgGestion)

	# Mets le BG tout en dessous
	move_child(BgGestion, 0)

	# plein écran (root Control)
	BgGestion.anchor_left = 0.0
	BgGestion.anchor_top = 0.0
	BgGestion.anchor_right = 1.0

func _try_cloud_load() -> void:
	var access: String = str(Session.access_token).strip_edges()
	if access == "":
		_set_status("Status: Pas connecté")
		_set_network_state("OFFLINE")
		_start_offline_poll()
		return
	if access.length() < 20:
		_set_status("Status: token invalide (len=%s)" % str(access.length()))
		_set_network_state("OFFLINE")
		_start_offline_poll()
		return

	var puuid: String = str(Session.profile_uuid).strip_edges()
	if puuid == "":
		_set_status("Status: Pas de profile_uuid")
		return

	_set_status("Status: Chargement cloud…")
	_inflight = "load"

	var url := API_BASE + PATH_CLOUD_LOAD + "?profile_uuid=%s" % puuid

	var headers := PackedStringArray()
	headers.append("Authorization: Bearer %s" % access)
	headers.append("Accept: application/json")

	var err := Http.request(url, headers, HTTPClient.METHOD_GET)
	if err != OK:
		_inflight = ""
		_set_status("Status: HTTP request() error %s" % str(err))


# ------------------------------------------------------------
# CLOUD SAVE (depuis user://savegame.json)
# ------------------------------------------------------------
func _try_cloud_save_from_local() -> void:
	if _inflight != "":
		print("[CLOUD_SAVE_SKIP] inflight=", _inflight)
		return
	var access: String = str(Session.access_token).strip_edges()
	if access == "" or access.length() < 20:
		_set_status("Status: Pas connecté (save)")
		_dirty_local = true
		_set_network_state("OFFLINE")
		_start_offline_poll()
		return

	var puuid: String = str(Session.profile_uuid).strip_edges()
	if puuid == "":
		_set_status("Status: Pas de profile_uuid (save)")
		return

	_ensure_local_savegame_exists()

	var local_parsed: Variant = _read_json_file(FILE_SAVEGAME)
	var blob_to_send: Dictionary = {}

	if typeof(local_parsed) == TYPE_DICTIONARY:
		blob_to_send = local_parsed
	else:
		blob_to_send = {}

	var checksum: String = _sha256_canonical_from_file(FILE_SAVEGAME)
	if checksum == "":
		var raw_txt2: String = _read_text_file(FILE_SAVEGAME)
		if raw_txt2.strip_edges() != "":
			checksum = _sha256_hex(raw_txt2)

	_set_status("Status: Upload cloud…")
	_inflight = "save"

	var payload := {
		"profile_uuid": puuid,
		"blob": blob_to_send,
		"checksum": checksum,
		"rev": int(Session.cloud_rev)
	}

	var headers := PackedStringArray()
	headers.append("Authorization: Bearer %s" % access)
	headers.append("Accept: application/json")
	headers.append("Content-Type: application/json")

	var body_txt: String = JSON.stringify(payload)

	var url := API_BASE + PATH_CLOUD_SAVE
	var err := Http.request(url, headers, HTTPClient.METHOD_POST, body_txt)
	if err != OK:
		_inflight = ""
		_set_status("Status: HTTP save request() error %s" % str(err))


# ------------------------------------------------------------
# HTTP CALLBACK UNIQUE (LOAD + SAVE)
# ------------------------------------------------------------
func _on_http_completed(result: int, response_code: int, _headers: PackedStringArray, body: PackedByteArray) -> void:
	var txt: String = body.get_string_from_utf8()

	# ---- NETWORK FAIL ----
	if result != OK:
		if _inflight == "load":
			_set_status("Status: Offline (load) result=%s" % str(result))
			print("[NET_FAIL][LOAD] result=", result, " code=", response_code)
			_set_network_state("OFFLINE")

			if _load_retry_count < LOAD_RETRY_MAX:
				var idx := _load_retry_count
				_load_retry_count += 1
				var dly := float(LOAD_BACKOFF_S[min(idx, LOAD_BACKOFF_S.size() - 1)])
				_inflight = ""
				_schedule_retry("load", dly)
				return

		elif _inflight == "save":
			_set_status("Status: Offline (save) result=%s" % str(result))
			print("[NET_FAIL][SAVE] result=", result, " code=", response_code)
			_set_network_state("OFFLINE")
			_dirty_local = true
			print("[OFFLINE] marked dirty_local=true")

			if _save_retry_count < SAVE_RETRY_MAX:
				var idx2 := _save_retry_count
				_save_retry_count += 1
				var dly2 := float(SAVE_BACKOFF_S[min(idx2, SAVE_BACKOFF_S.size() - 1)])
				_inflight = ""
				_schedule_retry("save", dly2)
				return

		_inflight = ""
		_rt_pending_reload = false
		return

	# Réseau OK → on repasse online
	_set_network_state("ONLINE")

	# ---- HTTP FAIL ----
	if response_code < 200 or response_code >= 300:
		if _inflight == "load":
			_set_status("Status: Cloud KO (%s)" % str(response_code))
			print("[CLOUD_BODY]", txt)
			_save_text_file(FILE_CLOUD_LAST_LOAD_TXT, txt)
			_load_retry_count = 0

			_inflight = ""
			_maybe_flush_dirty_local("load_http_fail_%s" % str(response_code))
			return

		elif _inflight == "save":
			_set_status("Status: Save KO (%s)" % str(response_code))
			print("[CLOUD_SAVE_BODY]", txt)
			_save_text_file(FILE_CLOUD_LAST_SAVE_TXT, txt)

			if response_code == 429 and txt.find("SAVE_COOLDOWN") != -1:
				_rt_cooldown_until_ms = Time.get_ticks_msec() + 3000 # 3s
				print("[DBG][RT] server cooldown -> client cooldown 3s")
				_dirty_local = true
				_inflight = ""
				_schedule_retry("save", 3.0)
				return

			_save_retry_count = 0
			_dirty_local = true
			_inflight = ""
			return

		_inflight = ""
		_rt_pending_reload = false
		return

	var parsed: Variant = JSON.parse_string(txt)

	# ---- 2xx ----
	if _inflight == "load":
		_set_status("Status: Cloud OK ✅")
		print("[CLOUD_OK_BODY]", txt)

		_load_retry_count = 0


		if typeof(parsed) == TYPE_DICTIONARY:
			_save_text_file(FILE_CLOUD_LAST_LOAD_JSON, JSON.stringify(parsed, "\t"))
		else:
			_save_text_file(FILE_CLOUD_LAST_LOAD_TXT, txt)

	elif _inflight == "save":
		_set_status("Status: Cloud OK ✅")
		_toast_status("Cloud synced ✅", 1.6)

		var is_empty: bool = false

		if typeof(parsed) == TYPE_DICTIONARY:
			var d: Dictionary = parsed as Dictionary

			if FileAccess.file_exists(FILE_NEW_CLUB_PENDING_CLOUD):
				print("[CLOUD_GUARD][HARD] skip entire cloud load because new club is pending")
				return

			Session.set_cloud_meta(d.get("rev", 0), d.get("checksum", ""))

			is_empty = (bool(d.get("found", true)) == false)

			var cloud_ck: String = str(d.get("checksum", ""))
			var local_ck_before: String = _sha256_canonical_from_file(FILE_SAVEGAME)
			var should_apply: bool = true

			# 🔒 GUARD: ne jamais écraser une save locale existante
			var local_exists: bool = FileAccess.file_exists(FILE_SAVEGAME)
			if local_exists:
				print("[APPLY_SKIP][LOCAL_PRIORITY] local save exists -> skip cloud overwrite")
				should_apply = false

			if cloud_ck != "" and local_ck_before != "":
				should_apply = (cloud_ck != local_ck_before)

			# NEW CLUB CLOUD GUARD:
			# si on vient de créer un nouveau club localement, ne jamais réappliquer un ancien blob cloud
			# du même email/profile_uuid quand le nom cloud diffère du local
			var _new_club_guard_active := FileAccess.file_exists(FILE_NEW_CLUB_PENDING_CLOUD)
			if _new_club_guard_active:
				var _local_any: Variant = _read_json_file(FILE_SAVEGAME)
				var _local_team_name := ""
				var _cloud_team_name := ""
				if typeof(_local_any) == TYPE_DICTIONARY:
					var _ld := _local_any as Dictionary
					_local_team_name = str(_ld.get("team_name", _ld.get("club_name", ""))).strip_edges()
				var _blob_any: Variant = d.get("blob", {})
				if typeof(_blob_any) == TYPE_DICTIONARY:
					var _bd := _blob_any as Dictionary
					_cloud_team_name = str(_bd.get("team_name", _bd.get("club_name", ""))).strip_edges()

				if _local_team_name != "" and _cloud_team_name != "" and _local_team_name != _cloud_team_name:
					print("[APPLY_SKIP][NEW_CLUB_GUARD] local_team=", _local_team_name, " cloud_team=", _cloud_team_name)
					should_apply = false

			print("[APPLY_DECISION] cloud_ck=", cloud_ck, " local_ck_before=", local_ck_before, " should_apply=", should_apply)

			if d.has("blob"):
				var blobv: Variant = d.get("blob")

				# ✅ ne jamais appliquer si le cloud dit "not found"
				if bool(d.get("found", true)) == false:
					print("[APPLY_SKIP] cloud found=false ignored")
					should_apply = false

				# ✅ ne jamais appliquer un cloud blob null
				if typeof(blobv) == TYPE_NIL:
					print("[APPLY_SKIP] cloud blob=null ignored")
					should_apply = false

				# ✅ ne jamais appliquer un cloud blob vide
				if typeof(blobv) == TYPE_DICTIONARY and (blobv as Dictionary).is_empty():
					print("[APPLY_SKIP] empty cloud blob ignored")
					should_apply = false

				# ✅ ne jamais downgrader un team_name local non vide avec un cloud team_name vide
				if typeof(blobv) == TYPE_DICTIONARY:
					var blobd: Dictionary = blobv as Dictionary
					var cloud_tn: String = str(blobd.get("team_name", "")).strip_edges()
					var local_now: Variant = _read_json_file(FILE_SAVEGAME)
					var local_tn: String = ""
					if typeof(local_now) == TYPE_DICTIONARY:
						local_tn = str((local_now as Dictionary).get("team_name", "")).strip_edges()
					if local_tn != "" and cloud_tn == "":
						print("[APPLY_SKIP] cloud empty team_name ignored (local team_name kept)")
						should_apply = false

				if typeof(blobv) == TYPE_DICTIONARY or typeof(blobv) == TYPE_ARRAY:
					_save_text_file(FILE_CLOUD_BLOB_JSON, JSON.stringify(blobv, "\t"))
					if should_apply:
						_save_text_file(FILE_SAVEGAME, JSON.stringify(blobv, "\t"))
						print("[APPLY] wrote local savegame.json from cloud blob")
						_just_loaded_from_cloud = true
					else:
						print("[APPLY] skipped (same checksum)")
				else:
					_save_text_file(FILE_CLOUD_BLOB_TXT, str(blobv))
					if should_apply:
						_save_text_file(FILE_SAVEGAME, str(blobv))
						print("[APPLY] wrote local savegame.json from cloud blob (txt)")
					else:
						print("[APPLY] skipped (same checksum)")

			var local_ck_after: String = _sha256_canonical_from_file(FILE_SAVEGAME)
			var chk: String = str(Session.get("cloud_checksum"))

			_save_text_file(FILE_CLOUD_LAST_APPLY_JSON, JSON.stringify({
				"applied_at_unix": Time.get_unix_time_from_system(),
				"cloud_rev": int(Session.cloud_rev),
				"cloud_checksum": chk,
				"local_checksum_before": local_ck_before,
				"local_checksum_after": local_ck_after,
				"should_apply": should_apply
			}, "\t"))

			print("[APPLY_META] rev=", int(Session.cloud_rev), " local_ck_after=", local_ck_after)
			print("[CHK] api_checksum=", str(d.get("checksum", "")), " local_after=", local_ck_after)

			if _rt_last_local_checksum != "":
				var ok_rt: bool = _roundtrip_validate_against_cloud_blob()
				print("[DBG][RT] RESULT=", ok_rt, " (expected true)")
				_rt_last_local_checksum = ""

		_inflight = ""
		_maybe_flush_dirty_local("load_ok")

		if is_empty and (not _did_auto_save):
			var local_ck: String = _sha256_canonical_from_file(FILE_SAVEGAME)
			if local_ck == "":
				print("[AUTO_SAVE] skipped: local_ck empty")
			else:
				_did_auto_save = true
				print("[AUTO_SAVE] cloud empty -> push local once, local_ck=", local_ck)
				call_deferred("_try_cloud_save_from_local")

		return

	if _inflight == "save":
		_set_status("Status: Save OK ✅")
		print("[CLOUD_SAVE_OK_BODY]", txt)

		_save_retry_count = 0
		_dirty_local = false

		var parsed2: Variant = JSON.parse_string(txt)
		if typeof(parsed2) == TYPE_DICTIONARY:
			var d2: Dictionary = parsed2 as Dictionary
			Session.set_cloud_meta(d2.get("rev", 0), d2.get("checksum", ""))
			_save_text_file(FILE_CLOUD_LAST_SAVE_JSON, JSON.stringify(d2, "\t"))
		else:
			_save_text_file(FILE_CLOUD_LAST_SAVE_TXT, txt)

		_inflight = ""

		_bm_lb_submit_from_save()

		if _rt_pending_reload:
			_rt_pending_reload = false
			print("[DBG][RT] push ok -> reload cloud")
			_try_cloud_load()

		return


# ------------------------------------------------------------
# ROUND-TRIP (F9)
# ------------------------------------------------------------
func _roundtrip_start() -> void:
	if _inflight != "":
		print("[DBG][RT] abort: inflight=", _inflight)
		return

	var now_ms: int = Time.get_ticks_msec()
	if now_ms < _rt_cooldown_until_ms:
		var left: float = float(_rt_cooldown_until_ms - now_ms) / 1000.0
		print("[DBG][RT] blocked by client cooldown, left=", left, "s")
		_set_status("Status: Cooldown (%.1fs)" % left)
		return

	_ensure_local_savegame_exists()

	var local: Variant = PL.load_savegame()
	if local == null or typeof(local) != TYPE_DICTIONARY:
		print("[DBG][RT] abort: local save not dict")
		return

	var d: Dictionary = local as Dictionary
	if not d.has("wallet") or typeof(d["wallet"]) != TYPE_DICTIONARY:
		d["wallet"] = {"euros": 0, "tokens": 0}

	if not d.has("meta") or typeof(d["meta"]) != TYPE_DICTIONARY:
		d["meta"] = {}
	(d["meta"] as Dictionary)["rt_bump_unix"] = Time.get_unix_time_from_system()

	_save_text_file(FILE_SAVEGAME, JSON.stringify(d, "\t"))

	_dirty_local = true
	print("[OFFLINE] local changed -> dirty_local=true")

	_rt_last_local_checksum = _sha256_canonical_from_file(FILE_SAVEGAME)
	print("[DBG][RT] local edited -> checksum_canon=", _rt_last_local_checksum)

	_rt_pending_reload = true
	call_deferred("_try_cloud_save_from_local")


func _roundtrip_validate_against_cloud_blob() -> bool:
	var local_ck: String = _sha256_canonical_from_file(FILE_SAVEGAME)

	var cloud_ck: String = ""
	if FileAccess.file_exists(FILE_CLOUD_BLOB_JSON):
		cloud_ck = _sha256_canonical_from_file(FILE_CLOUD_BLOB_JSON)
	elif FileAccess.file_exists(FILE_CLOUD_BLOB_TXT):
		cloud_ck = _sha256_file_hex(FILE_CLOUD_BLOB_TXT)

	print("[DBG][RT] validate local_ck_canon=", local_ck, " cloud_ck_canon=", cloud_ck, " rev=", int(Session.cloud_rev))
	return (local_ck != "" and cloud_ck != "" and local_ck == cloud_ck)



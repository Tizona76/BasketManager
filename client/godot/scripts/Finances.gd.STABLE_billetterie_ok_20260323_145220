const PlayerLife := preload("res://scripts/PlayerLife.gd")
func _i18n_lang2() -> String:
	var loc := TranslationServer.get_locale()
	if loc == null:
		return "en"
	var t := String(loc)
	if t.length() >= 2:
		return t.substr(0, 2).to_lower()
	return t.to_lower()


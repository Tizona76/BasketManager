const TOURNAMENT_PLAYER_BOOST_BASE: Dictionary = {
	"tournoi_a": 0.32,
	"intermediaire": 0.18,
	"elite": 0.08
}

const TOURNAMENT_SEASON_STEP: float = 0.03
const TOURNAMENT_RATING_WEIGHT: float = 0.006
const TOURNAMENT_RANK_WEIGHT: float = 0.025
const TOURNAMENT_BOOST_MIN: float = 0.00
const TOURNAMENT_BOOST_MAX: float = 0.60

static func get_tournament_player_boost(tournoi_id: String, season_number: int, team_rank: int, team_rating: float, global_coeff: float = 1.0) -> float:
	var base := float(TOURNAMENT_PLAYER_BOOST_BASE.get(tournoi_id, 0.0))

	# progression douce avec lva saison
	var season_coeff: float = 1.0 + float(max(0, season_number - 1)) * float(TOURNAMENT_SEASON_STEP)

	# rating : pivot simple autour de 60
	var rating_bonus: float = clamp(float((team_rating - 60.0) * float(TOURNAMENT_RATING_WEIGHT)), -0.08, 0.20)

	# classement : plus le rang est bon (1, 2, 3...), plus le bonus est fort
	var rank_bonus: float = clamp(float((8.0 - float(team_rank)) * float(TOURNAMENT_RANK_WEIGHT)), -0.05, 0.18)

	var total: float = float((base * season_coeff + rating_bonus + rank_bonus) * global_coeff)
	return clamp(total, float(TOURNAMENT_BOOST_MIN), float(TOURNAMENT_BOOST_MAX))

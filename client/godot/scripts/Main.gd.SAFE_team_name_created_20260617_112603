func _notification(what: int) -> void:
	if what == NOTIFICATION_WM_CLOSE_REQUEST:
		ProfileManager.flush_active_to_profile_file()

func _finish_web_guest_auth_silent() -> void:
	_web_guest_auth_pending = false
	if _web_team_name_requested:
		_web_team_name_requested = false
		call_deferred("_show_team_name")


func _try_guest_auth_silent() -> void:
	var http := HTTPRequest.new()
	add_child(http)

	var url := "https://api.basketmanager-game.com/v1/auth/guest"
	var headers := PackedStringArray(["Content-Type: application/json"])

	http.request_completed.connect(func(result, code, _h, body):
		if result == HTTPRequest.RESULT_SUCCESS and code >= 200 and code < 300:
			var parsed: Variant = JSON.parse_string((body as PackedByteArray).get_string_from_utf8())
			if typeof(parsed) == TYPE_DICTIONARY:
				var d := parsed as Dictionary
				var at := str(d.get("access_token", "")).strip_edges()
				var rt := str(d.get("refresh_token", "")).strip_edges()
				var tt := str(d.get("token_type", "Bearer")).strip_edges()
				if at.length() >= 20:
					Session.set_tokens(at, rt, tt)
					Session.profile_uuid = str(d.get("profile_uuid", "")).strip_edges()
					if Session.profile_uuid != "":
						ProfileManager.add_profile(Session.profile_uuid, Session.profile_uuid)
						ProfileManager.activate_profile(Session.profile_uuid)
						_save_session_local_from_main()
		_finish_web_guest_auth_silent()
		http.queue_free()
	)

	var request_error := http.request(url, headers, HTTPClient.METHOD_POST, "{}")
	if request_error != OK:
		_finish_web_guest_auth_silent()
		http.queue_free()


func _track_team_name_created(team_name: String) -> void:
	if str(Session.profile_uuid).strip_edges() == "":
		return

	var http := HTTPRequest.new()
	add_child(http)

	var url := "https://api.basketmanager-game.com/v1/funnel/team-name-created"
	var headers := PackedStringArray(["Content-Type: application/json"])

	var payload := {
		"profile_uuid": str(Session.profile_uuid),
		"team_name": str(team_name)
	}

	http.request_completed.connect(func(_result, _code, _h, _b):
		http.queue_free()
	)

	var request_error := http.request(url, headers, HTTPClient.METHOD_POST, JSON.stringify(payload))
	if request_error != OK:
		http.queue_free()



func _cloud_save(data: Dictionary) -> void:
	if str(Session.access_token).strip_edges().length() < 20:
		print("[CLOUD_SAVE] no token → skip")
		return

	var http := HTTPRequest.new()
	add_child(http)

	var url := "https://api.basketmanager-game.com/v1/cloud/save"

	var headers := PackedStringArray([
		"Content-Type: application/json",
		"Authorization: Bearer " + Session.access_token
	])

	var payload := {
		"profile_uuid": Session.profile_uuid,
		"blob": data
	}

	var body := JSON.stringify(payload)

	http.request_completed.connect(func(result, code, _h, _b):
		if result == HTTPRequest.RESULT_SUCCESS and code >= 200 and code < 300:
			print("[CLOUD_SAVE] success")
		else:
			print("[CLOUD_SAVE] failed code=", code)
	)

	http.request(url, headers, HTTPClient.METHOD_POST, body)

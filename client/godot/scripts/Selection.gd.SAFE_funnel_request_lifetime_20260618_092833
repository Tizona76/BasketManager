func _on_cards_scroll_changed(_value: float) -> void:
	call_deferred("_refresh_coverflow_deferred")

func _refresh_coverflow_deferred() -> void:
	_refresh_coverflow()

func _center_card_deferred() -> void:
	if box == null:
		return
	if box.get_child_count() <= 0:
		return
	carousel_active_index = clamp(carousel_active_index, 0, box.get_child_count() - 1)
	_center_card(carousel_active_index)
	_refresh_coverflow()

func _center_card(idx: int) -> void:
	if box == null or scroll == null:
		return
	if not (scroll is ScrollContainer):
		return
	if idx < 0 or idx >= box.get_child_count():
		return

	var sc := scroll as ScrollContainer
	var child: Control = box.get_child(idx) as Control
	if child == null:
		return

	await get_tree().process_frame

	var target: int = int((child.position.x + child.size.x * 0.5) - sc.size.x * 0.5)
	var max_scroll: int = max(0, int(box.size.x - sc.size.x))
	sc.scroll_horizontal = clamp(target, 0, max_scroll)

func _refresh_coverflow() -> void:
	if box == null:
		return
	if not (box is HBoxContainer):
		return
	if scroll == null or not (scroll is ScrollContainer):
		return
	if box.get_child_count() <= 0:
		return

	var hbox: HBoxContainer = box as HBoxContainer
	hbox.add_theme_constant_override("separation", CAROUSEL_NEG_SEPARATION)

	var sc := scroll as ScrollContainer
	var viewport_center_x: float = float(sc.scroll_horizontal) + sc.size.x * 0.5

	var cards: Array[Control] = []
	var best_idx: int = 0
	var best_dist: float = 1e18

	for i in range(box.get_child_count()):
		var card: Control = box.get_child(i) as Control
		if card == null:
			continue
		cards.append(card)
		card.pivot_offset = card.size * 0.5
		var cx: float = card.position.x + card.size.x * 0.5
		var dist: float = abs(cx - viewport_center_x)
		if dist < best_dist:
			best_dist = dist
			best_idx = i

	carousel_active_index = best_idx

	var active_card: Control = null

	for i in range(box.get_child_count()):
		var card: Control = box.get_child(i) as Control
		if card == null:
			continue

		var delta: int = abs(i - best_idx)
		var sxy: float = CAROUSEL_SCALE_FAR
		var alpha: float = CAROUSEL_ALPHA_FAR
		var rot: float = 0.0

		if delta == 0:
			sxy = CAROUSEL_SCALE_CENTER
			alpha = CAROUSEL_ALPHA_CENTER
			rot = 0.0
			active_card = card
		elif delta == 1:
			sxy = CAROUSEL_SCALE_NEAR
			alpha = CAROUSEL_ALPHA_NEAR
			rot = -CAROUSEL_ROT_DEG_NEAR if i < best_idx else CAROUSEL_ROT_DEG_NEAR
		else:
			sxy = CAROUSEL_SCALE_FAR
			alpha = CAROUSEL_ALPHA_FAR
			rot = -CAROUSEL_ROT_DEG_FAR if i < best_idx else CAROUSEL_ROT_DEG_FAR

		card.scale = Vector2(sxy, sxy)
		card.rotation_degrees = rot
		card.modulate.a = alpha

	# Ne pas déplacer active_card : sinon l'ordre visuel du tri est cassé.
	# Le coverflow garde le zoom/alpha, mais respecte l'ordre des joueurs.
	#if active_card != null:
	#	box.move_child(active_card, box.get_child_count() - 1)

func _scan_avatar_portraits(path: String) -> Array[String]:
	var res: Array[String] = []

	# 1) Desktop/Editor: listing réel du dossier (rapide)
	var d: DirAccess = DirAccess.open(path)
	if d != null:
		d.list_dir_begin()
		while true:
			var f: String = d.get_next()
			if f == "":
				break
			if d.current_is_dir():
				continue

			var lf: String = f.to_lower()
			# ✅ ne garder que les portraits, pas les layers/masks
			if not lf.begins_with("avatar_"):
				continue
			if lf.ends_with(".png") or lf.ends_with(".webp") or lf.ends_with(".jpg") or lf.ends_with(".jpeg"):
				res.append(f)
		d.list_dir_end()

	res.sort()

	# 2) HTML5 fallback: DirAccess peut renvoyer vide même si c'est dans le .pck
	if res.size() == 0:
		# On "probe" des fichiers connus : avatar_01..avatar_60 (+ variantes)
		var exts: Array[String] = [".png", ".webp", ".jpg", ".jpeg"]
		for i in range(1, 61):
			var a2 := "avatar_%02d" % i
			var a1 := "avatar_%d" % i
			for base in [a2, a1]:
				for ext in exts:
					var p: String = path + "/" + base + ext
					if ResourceLoader.exists(p):
						res.append(base + ext)
						break

		# variantes spécifiques (si tu en as)
		for ext in exts:
			var p2: String = path + "/avatar_10B" + ext
			if ResourceLoader.exists(p2):
				res.append("avatar_10B" + ext)
				break

		res.sort()

	return res



func _avatar_players() -> Array:
	var base_root: String = "res://assets/images/avatars"
	var base_used: String = base_root
	var files: Array[String] = []

	# 1) Essai: racine (compat si tu y mets des avatar_01.png un jour)
	files = _scan_avatar_portraits(base_root)

	# 2) Fallback: avatars_dessin (TON cas actuel)
	if files.size() == 0:
		base_used = base_root + "/avatars_dessin"
		files = _scan_avatar_portraits(base_used)

	# 3) Si toujours rien -> dummy (évite liste vide)
	if files.size() == 0:
		push_error("[SELECTION] no avatar portraits found in " + base_root + " or avatars_dessin -> fallback dummy")
		return _dummy_players()

	var out: Array = []
	var n: int = mini(16, files.size())

	# 1) hommes d'abord
	var males: Array = []
	var females: Array = []

	for fname in files:
		var avatar_key: String = fname.get_basename()
		var gender: String = "U"

		for k in _meta_key_candidates(avatar_key):
			if avatar_meta.has(k):
				gender = str(avatar_meta[k].get("gender", "U"))
				break

		if gender == "M":
			males.append(fname)
		else:
			females.append(fname)

	var ordered := males + females

	for i: int in range(mini(n, ordered.size())):
		var fname: String = ordered[i]
		var avatar_key: String = fname.get_basename()

		# Par défaut : nom lisible depuis filename
		var gender: String = "U"
		var first_name: String = avatar_key.replace("_", " ")

		# CSV override (robuste: avatar_10 / avatar_010 / avatar_10B / avatar_010B / etc.)
		var cands: Array[String] = _meta_key_candidates(avatar_key)
		for k: String in cands:
			if avatar_meta.has(k):
				var m: Dictionary = avatar_meta[k] as Dictionary
				gender = str(m.get("gender", "U"))
				first_name = str(m.get("first_name", first_name))
				break

		out.append({
			"id": i,
			"avatar_key": avatar_key,
			"gender": gender,
			"name": first_name,
			"avatar_path": base_used + "/" + fname,
			"pos": "",
			"rating": ""
		})

	print("[SELECTION] avatar_players=", n, " from ", base_used)
	return out


func _print_node_map() -> void:
	print("[SELECTION][NODES] box=", _p(box),
		" lbl_count=", _p(lbl_count),
		" box_buttons=", _p(box_buttons),
		" scroll=", _p(scroll))
	print("[SELECTION][NODES] btn_val=", _p(btn_val), " btn_back=", _p(btn_back))
	if btn_val == null or btn_back == null:
		print("[SELECTION][WARN] Missing buttons => check your scene names: BtnValider / BtnRetour")


func _p(n: Node) -> String:
	if n == null:
		return "NULL"
	return "%s (%s)" % [str(n.get_path()), n.get_class()]


func _selection_team_name_text() -> String:
	var save: Dictionary = PL.load_savegame()
	if typeof(save) == TYPE_DICTIONARY:
		var name := ""
		name = str(save.get("team_name", "")).strip_edges()
		if name == "":
			name = str(save.get("teamName", "")).strip_edges()
		if name == "":
			name = str(save.get("club_name", "")).strip_edges()
		if name == "":
			name = str(save.get("clubName", "")).strip_edges()
		if name == "" and save.has("team") and typeof(save["team"]) == TYPE_DICTIONARY:
			name = str((save["team"] as Dictionary).get("name", "")).strip_edges()
		if name != "":
			return name.to_upper()
	return ""

func _ensure_center_team_label() -> void:
	if not (btn_val is Control):
		return

	var btn_val_ctrl := btn_val as Control
	var lbl := get_node_or_null("LblTeamCenter") as Label
	if lbl == null:
		lbl = Label.new()
		lbl.name = "LblTeamCenter"
		add_child(lbl)

	var team_name := _selection_team_name_text()
	if team_name == "":
		lbl.visible = false
		return

	lbl.visible = true
	lbl.text = team_name
	lbl.mouse_filter = Control.MOUSE_FILTER_IGNORE
	lbl.z_index = 12
	lbl.set_as_top_level(true)
	lbl.add_theme_color_override("font_color", Color(0.10, 0.42, 0.95, 1.0))
	lbl.add_theme_color_override("font_outline_color", Color(0.02, 0.10, 0.28, 0.95))
	lbl.add_theme_color_override("font_shadow_color", Color(0, 0, 0, 0.28))
	lbl.add_theme_constant_override("outline_size", 3)
	lbl.add_theme_font_size_override("font_size", 36)
	lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER

	var vp := get_viewport_rect().size
	var btn_sz := btn_val_ctrl.size
	if btn_sz.x <= 1.0 or btn_sz.y <= 1.0:
		btn_sz = btn_val_ctrl.get_combined_minimum_size()

	var lbl_sz := lbl.get_combined_minimum_size()
	lbl.position = Vector2(
		(vp.x - lbl_sz.x) / 2.0,
		btn_val_ctrl.global_position.y - lbl_sz.y - 14.0
	)


func _get_node_typed(path: String, t: Variant) -> Node:
	var n := get_node_or_null(path)
	if n == null:
		return null
	if t == BaseButton and (n is BaseButton):
		return n
	if t == Control and (n is Control):
		return n
	if t == VBoxContainer and (n is VBoxContainer):
		return n
	if t == Label and (n is Label):
		return n
	return null


func _on_back() -> void:
	print("[SELECTION] BACK pressed")
	emit_signal("back_requested")


func _connect_sort_header(node_name: String, sort_key: String) -> void:
	var b := get_node_or_null(node_name) as BaseButton
	if b == null:
		b = find_child(node_name, true, false) as BaseButton
	if b == null:
		return
	b.mouse_filter = Control.MOUSE_FILTER_STOP
	var cb := Callable(self, "_on_sort_header_pressed").bind(sort_key)
	if not b.pressed.is_connected(cb):
		b.pressed.connect(cb)

func _on_sort_header_pressed(sort_key: String) -> void:
	if current_sort_key == sort_key:
		current_sort_ascending = not current_sort_ascending
	else:
		current_sort_key = sort_key
		current_sort_ascending = true
	_refresh_players_view()

func _refresh_players_view() -> void:
	if current_players_source.is_empty():
		_build_list([])
		return

	var players: Array = []
	for p_raw in current_players_source:
		var p: Dictionary = (p_raw as Dictionary).duplicate(true)
		var j_ui: Dictionary = _bm_init_player_from_avatar(p)
		for k in j_ui.keys():
			p[k] = j_ui[k]
		p["stars"] = _selection_star_count(p)
		p["bm_selection_mobile_rating_ratio"] = _selection_is_mobile_layout()
		players.append(p)

	if current_sort_key != "":
		_sort_players_in_place(players, current_sort_key, current_sort_ascending)

	_update_sort_header_titles()
	_build_list(players)


func _selection_star_count(d: Dictionary) -> int:
	var tir := int(d.get("tir", 0))
	var vitesse := int(d.get("vitesse", 0))
	var defense := int(d.get("defense", 0))
	var motivation := int(d.get("motivation", 0))
	var avg := int(round(float(tir + vitesse + defense + motivation) / 4.0))
	return clampi(int(round(float(avg) / 20.0)), 1, 5)

func _sort_players_in_place(players: Array, sort_key: String, ascending: bool) -> void:
	players.sort_custom(func(a, b):
		var da: Dictionary = a as Dictionary
		var db: Dictionary = b as Dictionary
		var av = da.get(sort_key, 0)
		var bv = db.get(sort_key, 0)

		if sort_key == "stars":
			var asv_star := _selection_star_count(da)
			var bsv_star := _selection_star_count(db)
			if asv_star == bsv_star:
				return int(da.get("id", 0)) < int(db.get("id", 0)) if ascending else int(da.get("id", 0)) > int(db.get("id", 0))
			return asv_star < bsv_star if ascending else asv_star > bsv_star

		if sort_key == "tir":
			var asv := int(av)
			var bsv := int(bv)
			return asv < bsv if ascending else asv > bsv

		if sort_key == "poste":
			var asv2 := str(av)
			var bsv2 := str(bv)
			return asv2 < bsv2 if ascending else asv2 > bsv2

		if sort_key == "precision":
			var af := str(av).to_float()
			var bf := str(bv).to_float()
			return af < bf if ascending else af > bf

		var ai := str(av).to_int()
		var bi := str(bv).to_int()
		return ai < bi if ascending else ai > bi
	)

func _update_sort_header_titles() -> void:
	var labels := {
		"HeaderStars": "⭐",
		"HeaderPos": "POS.",
		"HeaderAge": "AGE",
		"HeaderGender": tr("player.attr.tir"),
		"HeaderSpeed": "SPEED",
		"HeaderDefense": "DEFENSE",
		"HeaderPrecision": "ACCURACY",
		"HeaderMotivation": tr("selection.header.motivation"),
		"HeaderSalary": "SALARY",
	}
	for node_name in labels.keys():
		var b := get_node_or_null(node_name) as BaseButton
		if b == null:
			b = find_child(node_name, true, false) as BaseButton
		if b == null:
			continue
		var txt := str(labels[node_name])
		if node_name == "HeaderStars" and _selection_is_mobile_layout():
			txt = "RAT."
		var key := ""
		match node_name:
			"HeaderStars":
				key = "stars"
			"HeaderPos":
				key = "poste"
			"HeaderAge":
				key = "age"
			"HeaderGender":
				key = "tir"
			"HeaderSpeed":
				key = "vitesse"
			"HeaderDefense":
				key = "defense"
			"HeaderPrecision":
				key = "precision"
			"HeaderMotivation":
				key = "motivation"
			"HeaderSalary":
				key = "salaire"
		if current_sort_key == key:
			txt += " ↑" if current_sort_ascending else " ↓"
		b.text = txt
		if _selection_is_mobile_layout() and not b.has_meta("bm_selection_mobile_header_plus1_done"):
			b.set_meta("bm_selection_mobile_header_plus1_done", true)
			var fs: int = int(b.get_theme_font_size("font_size"))
			if fs > 0:
				b.add_theme_font_size_override("font_size", fs + 1)

func _build_list(players: Array) -> void:
	row_by_id.clear()
	player_data_by_id.clear()
	selected_ids.clear()

	for c in box.get_children():
		c.queue_free()

	var cb_row := Callable(self, "_on_row_toggled")
	var cb_photo := Callable(self, "_bm_show_player_card_popup")

	for p in players:
		var row: Node = PlayerRowPS.instantiate()

		if not row.has_method("setup"):
			push_error("[SELECTION] PlayerRow has no setup() -> check PlayerRow.tscn script attachment")
			print("[SELECTION] row class=", row.get_class(), " script=", row.get_script())
			return

		var p_ui: Dictionary = p.duplicate(true)
		var j_ui: Dictionary = _bm_init_player_from_avatar(p)
		for k in j_ui.keys():
			p_ui[k] = j_ui[k]
		row.call("setup", p_ui)

		var pid: int = int(p.get("id", -1))
		player_data_by_id[pid] = p_ui.duplicate(true)
		if pid >= 0:
			row_by_id[pid] = row

		# ✅ CONNECT toggled (robuste)
			if row.has_signal("toggled"):
				if row.is_connected("toggled", cb_row):
					row.disconnect("toggled", cb_row)
				row.connect("toggled", cb_row)
			else:
				push_warning("[SELECTION] PlayerRow has no signal 'toggled'")

			if row.has_signal("photo_pressed"):
				if row.is_connected("photo_pressed", cb_photo):
					row.disconnect("photo_pressed", cb_photo)
				row.connect("photo_pressed", cb_photo)

			box.add_child(row)


	_refresh_quota_ui()
	_update_selection_top_stats()
	_bm_refresh_selection_crest_popup()


func _on_row_toggled(pid: int) -> void:
	if pid in selected_ids:
		selected_ids.erase(pid)
		_update_ui()
		_refresh_quota_ui()
		_update_selection_top_stats()
		_bm_refresh_selection_crest_popup()
		call_deferred("_center_card_deferred")
		return

	if selected_ids.size() >= MAX_SEL:
		print("[SELECTION] max reached")
		_refresh_quota_ui()
		_update_selection_top_stats()
		return

	selected_ids.append(pid)
	_update_ui()
	_refresh_quota_ui()
	_update_selection_top_stats()
	_bm_refresh_selection_crest_popup()


func _bm_player_card_tr(key: String, fallback: String) -> String:
	var v := tr(key)
	if v == key or v.strip_edges() == "":
		return fallback
	return v


func _bm_player_card_position_text(poste: String) -> String:
	match String(poste).strip_edges().to_lower():
		"meneur", "point guard":
			return _bm_player_card_tr("player.position.point_guard", "Point Guard")
		"arrière", "arriere", "shooting guard":
			return _bm_player_card_tr("player.position.shooting_guard", "Shooting Guard")
		"ailier", "small forward":
			return _bm_player_card_tr("player.position.small_forward", "Small Forward")
		"ailier fort", "power forward":
			return _bm_player_card_tr("player.position.point_forward", "Power Forward")
		"pivot", "center":
			return _bm_player_card_tr("player.position.center", "Center")
		_:
			return poste


func _bm_player_card_close() -> void:
	var existing := get_node_or_null("PlayerCardPopup")
	if existing != null and is_instance_valid(existing):
		existing.queue_free()


func _bm_player_card_salary(n: int) -> String:
	var s := str(n)
	var out := ""
	var count := 0
	for i in range(s.length() - 1, -1, -1):
		out = s.substr(i, 1) + out
		count += 1
		if count % 3 == 0 and i > 0:
			out = " " + out
	return out + " €"


func _bm_player_card_percent(value: Variant) -> float:
	var f := float(value)
	if f <= 1.5:
		f *= 100.0
	return clampf(f, 0.0, 100.0)


func _bm_player_card_add_label(parent: Control, text_value: String, pos: Vector2, sz: Vector2, fs: int, color: Color, center: bool = false) -> Label:
	var lbl := Label.new()
	lbl.text = text_value
	lbl.position = pos
	lbl.size = sz
	lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER if center else HORIZONTAL_ALIGNMENT_LEFT
	lbl.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	lbl.add_theme_font_size_override("font_size", fs)
	lbl.add_theme_color_override("font_color", color)
	lbl.add_theme_color_override("font_outline_color", Color(0.01, 0.02, 0.05, 0.95))
	lbl.add_theme_constant_override("outline_size", 2)
	parent.add_child(lbl)
	return lbl


func _bm_player_card_add_stat(parent: VBoxContainer, label_text: String, value: Variant, keep_decimals: bool = false) -> void:
	var row := HBoxContainer.new()
	row.custom_minimum_size = Vector2(0, 28)
	row.add_theme_constant_override("separation", 10)
	parent.add_child(row)

	var lbl := Label.new()
	lbl.text = label_text
	lbl.custom_minimum_size = Vector2(130, 26)
	lbl.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	lbl.add_theme_font_size_override("font_size", 17)
	lbl.add_theme_color_override("font_color", Color(0.92, 0.95, 1.0, 1.0))
	row.add_child(lbl)

	var track := ColorRect.new()
	track.custom_minimum_size = Vector2(180, 10)
	track.color = Color(1, 1, 1, 0.18)
	row.add_child(track)

	var bar := ColorRect.new()
	bar.color = Color(0.95, 0.50, 0.12, 1.0)
	bar.position = Vector2(0, 0)
	bar.size = Vector2(180.0 * (_bm_player_card_percent(value) / 100.0), 10)
	track.add_child(bar)

	var val := Label.new()
	val.text = ("%.2f" % float(value)) if keep_decimals else str(int(round(float(value))))
	val.custom_minimum_size = Vector2(52, 26)
	val.horizontal_alignment = HORIZONTAL_ALIGNMENT_RIGHT
	val.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	val.add_theme_font_size_override("font_size", 17)
	val.add_theme_color_override("font_color", Color(1, 1, 1, 1))
	row.add_child(val)



class PlayerProfileQuadrantGraph extends Control:
	var scores: Dictionary = {}

	func set_scores(v: Dictionary) -> void:
		scores = v
		queue_redraw()

	func _draw() -> void:
		_bm_draw_duel_graph(Vector2(50.0, 76.0), 50.8, "attaque", "defense", tr("player.card.graph.attack"), tr("player.card.graph.defense"), Color(0.88, 0.32, 0.12, 0.94), Color(0.24, 0.47, 0.68, 0.94))
		_bm_draw_duel_graph(Vector2(176.0, 76.0), 50.8, "physique", "mental", tr("player.card.graph.physical"), tr("player.card.graph.mental"), Color(0.88, 0.62, 0.18, 0.94), Color(0.48, 0.30, 0.62, 0.94))

	func _bm_draw_duel_graph(center: Vector2, radius: float, key_a: String, key_b: String, label_a: String, label_b: String, color_a: Color, color_b: Color) -> void:
		var value_a := clampf(float(scores.get(key_a, 0.0)), 0.0, 100.0)
		var value_b := clampf(float(scores.get(key_b, 0.0)), 0.0, 100.0)
		var total: float = max(1.0, value_a + value_b)
		var split_angle: float = -PI * 0.5 + TAU * (value_a / total)
		var font := get_theme_default_font()

		_bm_draw_sector(center, radius, -PI * 0.5, split_angle, color_a)
		_bm_draw_sector(center, radius, split_angle, -PI * 0.5 + TAU, color_b)
		draw_arc(center, radius, 0.0, TAU, 64, Color(1, 1, 1, 0.38), 2.0)
		draw_circle(center, radius * 0.16, Color(0.04, 0.07, 0.12, 0.88))

		var mid_a: float = (-PI * 0.5 + split_angle) * 0.5
		var mid_b: float = (split_angle + (-PI * 0.5 + TAU)) * 0.5
		var pos_a := center + Vector2(cos(mid_a), sin(mid_a)) * (radius * 0.52)
		var pos_b := center + Vector2(cos(mid_b), sin(mid_b)) * (radius * 0.52)
		draw_string(font, pos_a - Vector2(13, -6), str(int(round(value_a))), HORIZONTAL_ALIGNMENT_LEFT, -1, 17, Color(1, 1, 1, 1))
		draw_string(font, pos_b - Vector2(13, -6), str(int(round(value_b))), HORIZONTAL_ALIGNMENT_LEFT, -1, 17, Color(1, 1, 1, 1))
		draw_string(font, center + Vector2(-34, -60), label_a, HORIZONTAL_ALIGNMENT_LEFT, -1, 17, Color(1, 1, 1, 0.94))
		draw_string(font, center + Vector2(-22, 66), label_b, HORIZONTAL_ALIGNMENT_LEFT, -1, 17, Color(1, 1, 1, 0.94))
		draw_line(center + Vector2(-11, -39), center + Vector2(-20, -53), Color(1, 1, 1, 0.62), 1.0)
		draw_line(center + Vector2(14, 39), center + Vector2(32, 58), Color(1, 1, 1, 0.62), 1.0)

	func _bm_draw_sector(center: Vector2, radius: float, start_angle: float, end_angle: float, color: Color) -> void:
		var pts: PackedVector2Array = [center]
		for step in range(25):
			var a: float = start_angle + ((end_angle - start_angle) * float(step) / 24.0)
			pts.append(center + Vector2(cos(a), sin(a)) * radius)
		draw_polygon(pts, PackedColorArray([color]))


func _bm_player_profile_scores(data: Dictionary) -> Dictionary:
	var precision := float(data.get("precision", 0.0))
	if precision <= 1.5:
		precision *= 100.0
	var pct_2pts := float(data.get("pct_2pts", precision))
	if pct_2pts <= 1.5:
		pct_2pts *= 100.0
	var pct_3pts := float(data.get("pct_3pts", precision))
	if pct_3pts <= 1.5:
		pct_3pts *= 100.0
	var attaque := (float(data.get("tir", 0)) + precision + pct_2pts + pct_3pts) / 4.0
	var defense_score := float(data.get("defense", 0))
	var mental := float(data.get("motivation", 0))
	var fatigue_score := 100.0 - float(data.get("fatigue", 0))
	var physique := (float(data.get("vitesse", 0)) + float(data.get("endurance", 0)) + fatigue_score) / 3.0
	return {
		"attaque": clampf(attaque, 0.0, 100.0),
		"defense": clampf(defense_score, 0.0, 100.0),
		"mental": clampf(mental, 0.0, 100.0),
		"physique": clampf(physique, 0.0, 100.0),
	}



func _bm_show_player_graph_tooltip(card: Control, anchor: Control, text_value: String) -> void:
	var tooltip := card.get_node_or_null("PlayerProfileGraphCustomTooltip") as Panel
	if tooltip == null:
		tooltip = Panel.new()
		tooltip.name = "PlayerProfileGraphCustomTooltip"
		tooltip.mouse_filter = Control.MOUSE_FILTER_IGNORE
		tooltip.z_index = 80
		var sb := StyleBoxFlat.new()
		sb.bg_color = Color(0.02, 0.03, 0.06, 0.96)
		sb.corner_radius_top_left = 8
		sb.corner_radius_top_right = 8
		sb.corner_radius_bottom_left = 8
		sb.corner_radius_bottom_right = 8
		sb.border_width_left = 1
		sb.border_width_top = 1
		sb.border_width_right = 1
		sb.border_width_bottom = 1
		sb.border_color = Color(1.0, 0.58, 0.14, 0.65)
		tooltip.add_theme_stylebox_override("panel", sb)
		card.add_child(tooltip)

		var lbl := Label.new()
		lbl.name = "LblGraphTooltip"
		lbl.mouse_filter = Control.MOUSE_FILTER_IGNORE
		lbl.position = Vector2(12, 10)
		lbl.size = Vector2(414, 102)
		lbl.autowrap_mode = TextServer.AUTOWRAP_WORD_SMART
		lbl.add_theme_font_size_override("font_size", 16)
		lbl.add_theme_color_override("font_color", Color(1, 1, 1, 1))
		tooltip.add_child(lbl)

	var tooltip_h := 118.0
	var label := tooltip.get_node_or_null("LblGraphTooltip") as Label
	if label != null:
		var display_text := text_value
		var line_count: int = max(1, display_text.split("\n").size())
		tooltip_h = max(118.0, float(line_count) * 24.0 + 38.0)
		label.text = display_text
		label.size = Vector2(414, tooltip_h - 12.0)

	tooltip.size = Vector2(442, tooltip_h)
	var desired := Vector2(anchor.position.x, -tooltip.size.y - 8.0)
	var max_x: float = max(0.0, card.size.x - tooltip.size.x - 12.0)
	tooltip.position = Vector2(clampf(desired.x, 12.0, max_x), desired.y)
	tooltip.visible = true
	card.move_child(tooltip, card.get_child_count() - 1)


func _bm_hide_player_graph_tooltip(card: Control) -> void:
	var tooltip := card.get_node_or_null("PlayerProfileGraphCustomTooltip") as Control
	if tooltip != null:
		tooltip.visible = false

func _bm_add_player_profile_graph(card: Control, data: Dictionary) -> void:
	var graph := PlayerProfileQuadrantGraph.new()
	graph.name = "PlayerProfileGraph"
	graph.mouse_filter = Control.MOUSE_FILTER_IGNORE
	graph.size = Vector2(249, 249)
	graph.position = Vector2(488, 24)
	graph.set_scores(_bm_player_profile_scores(data))
	card.add_child(graph)

	var graph_tip_left := Control.new()
	graph_tip_left.name = "PlayerProfileGraphAttackDefenseTooltipArea"
	graph_tip_left.mouse_filter = Control.MOUSE_FILTER_STOP
	graph_tip_left.size = Vector2(118, graph.size.y)
	graph_tip_left.position = graph.position
	graph_tip_left.tooltip_text = ""
	graph_tip_left.mouse_entered.connect(func() -> void:
		_bm_show_player_graph_tooltip(card, graph_tip_left, tr("player.card.graph.tooltip.attack_defense"))
	)
	graph_tip_left.mouse_exited.connect(func() -> void:
		_bm_hide_player_graph_tooltip(card)
	)
	card.add_child(graph_tip_left)

	var graph_tip_right := Control.new()
	graph_tip_right.name = "PlayerProfileGraphPhysicalMentalTooltipArea"
	graph_tip_right.mouse_filter = Control.MOUSE_FILTER_STOP
	graph_tip_right.size = Vector2(131, graph.size.y)
	graph_tip_right.position = graph.position + Vector2(118, 0)
	graph_tip_right.tooltip_text = ""
	graph_tip_right.mouse_entered.connect(func() -> void:
		_bm_show_player_graph_tooltip(card, graph_tip_right, tr("player.card.graph.tooltip.physical_mental"))
	)
	graph_tip_right.mouse_exited.connect(func() -> void:
		_bm_hide_player_graph_tooltip(card)
	)
	card.add_child(graph_tip_right)


	if get_node_or_null("PlayerCardPopup") != null:
		return

	var popup := Control.new()
	popup.name = "PlayerCardPopup"
	popup.set_anchors_preset(Control.PRESET_FULL_RECT)
	popup.mouse_filter = Control.MOUSE_FILTER_STOP
